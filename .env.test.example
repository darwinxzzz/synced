# E2E and integration test credentials - copy this to .env.test and fill in real values
# .env.test is gitignored and never committed

# Supabase target used by integration tests
# These can also be supplied by .env, which is loaded before .env.test.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Member account (role = member, status = active, MFA enrolled)
TEST_MEMBER_EMAIL=member@example.com
TEST_MEMBER_PASSWORD=yourpassword

# Admin account (role = admin, status = active, MFA enrolled)
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=yourpassword
