# Since the ".env" file is gitignored, use this file as a template.
# Copy to ".env" and populate with your secrets.
# When adding new variables, also update the schema in "/src/env.js".

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a new secret with: npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# NextAuth Discord Provider
# https://discord.com/developers/applications
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

